# ════════════════════════════════════════════════════════════════
#  Configuração do pipeline — copia para workspace/.env e preenche
#     cp config/.env.example .env
#
#  NOTA DE SEGURANÇA: a password do Ubuntu One NÃO entra aqui.
#  O login é feito uma única vez, interativamente (com suporte a
#  2FA), via "pipeline.sh setup". O token fica em .credentials/.
# ════════════════════════════════════════════════════════════════

# ── Chave de assinatura ──────────────────────────────────────────
# Nome da chave GPG usada para assinar model e system-user
KEY_NAME=mestrado-iot

# Passphrase da chave privada.
# Deixa VAZIO para criar a chave sem passphrase (builds em CI;
# menos seguro — só recomendado em ambientes descartáveis).
KEY_PASSPHRASE=

# ── Modelo (assertion "model") ───────────────────────────────────
MODEL_NAME=rpi5-gateway
ARCHITECTURE=arm64
BASE=core24
# dangerous = desenvolvimento; signed = produção
GRADE=dangerous

# ── Utilizador do sistema (assertion "system-user") ──────────────
# As chaves SSH vão em config/ssh-authorized-keys (uma por linha)
SYSTEM_USER_EMAIL=XXXXX@XXXXX
SYSTEM_USER_USERNAME=XXXXX
SYSTEM_USER_FULLNAME="XXXXX"
# Validade da asserção, em anos, a partir da data do build
SYSTEM_USER_VALID_YEARS=10

# ── Opções de build ──────────────────────────────────────────────
# true = comprime a imagem final com xz (ideal para arquivar/enviar)
COMPRESS_IMAGE=false
